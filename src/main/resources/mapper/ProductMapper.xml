<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ncyysf.mapper.ProductMapper">

    <resultMap id="productResultMap" type="com.ncyysf.entity.Product">
        <id property="id" column="id"/>
        <result property="goodsName" column="goods_name"/>
        <result property="price" column="price"/>
        <result property="stock" column="stock"/>
        <result property="category" column="category"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <insert id="insert" parameterType="com.ncyysf.entity.Product"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO product (goods_name, price, stock, category, create_time)
        VALUES (#{goodsName}, #{price}, #{stock}, #{category}, #{createTime})
    </insert>

    <delete id="deleteById">
        DELETE FROM product WHERE id = #{id}
    </delete>

    <update id="update" parameterType="com.ncyysf.entity.Product">
        UPDATE product
        SET goods_name = #{goodsName},
            price = #{price},
            stock = #{stock},
            category = #{category},
            create_time = #{createTime}
        WHERE id = #{id}
    </update>

    <select id="selectById" resultMap="productResultMap">
        SELECT * FROM product WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="productResultMap">
        SELECT * FROM product ORDER BY create_time DESC
    </select>

</mapper>
